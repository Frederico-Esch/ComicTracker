<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ComicTracking.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComicTracking"
    xmlns:domain="using:Domain"
    xmlns:userControls="using:ComicTracking.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Window"
    Title="ComicTracking" Closed="WindowClosed">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="5" x:Name="WindowXamlRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="5" ColumnSpacing="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <!--
            <Button Grid.Column="0" Click="ButtonManageTags">Manage Tags</Button>
            -->
            <Button Grid.Column="0" Click="ButtonManageTags"
                    Padding="8">
                <SymbolIcon Symbol="Tag"/>
            </Button>
            <!--
            <Button Grid.Column="1" Click="FilterTags">Filter Tags</Button>
            -->
            <Button Grid.Column="1" Click="FilterTags"
                    Padding="8">
                <SymbolIcon Symbol="Filter"/>
            </Button>
            <TextBox Grid.Column="2"/>
            <Button Grid.Column="3"
                    Padding="8"
                    FontSize="18" FontFamily="Segoe Fluent Icons" Content="&#57623;"
                    Click="ButtonReload"
                    Background="MediumPurple"
            />
        </Grid>

        <GridView x:Name="ComicList" CanReorderItems="True" AllowDrop="True"
                  Background="Transparent" Grid.Row="1" Padding="10"
                  SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="domain:Comic">
                    <userControls:ComicCard DataContext="{Binding Mode=OneWay}" AllowDrop="False" >
                        <userControls:ComicCard.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open"   Tag="open"   Icon="OpenLOcal" Click="ContextOpen"/>
                                <MenuFlyoutItem Text="Edit"   Tag="edit"   Icon="Edit"      Click="ContextEdit"/>
                                <MenuFlyoutItem Text="Delete" Tag="delete" Icon="Delete"    Click="ContextDelete"/>
                            </MenuFlyout>
                        </userControls:ComicCard.ContextFlyout>
                    </userControls:ComicCard>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Button
            Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Right"
            Margin="20" Padding="10"
            Background="CornflowerBlue" CornerRadius="20"
            FontSize="25" FontFamily="Segoe Fluent Icons" Content="&#57609;" 
            Click="CreateComic"
            />

    </Grid>
</Window>
