<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ComicTracking.Windows.FilterTagsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComicTracking.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:domain="using:Domain"
    xmlns:uc="using:ComicTracking.UserControls"
    mc:Ignorable="d"
    Title="Filter Tags">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Loaded="Loaded" Margin="10" RowSpacing="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TagFilterBox" Grid.Column="0"/>

            <ComboBox x:Name="FilterTypeCombo" Grid.Column="1" SelectedIndex="0" SelectionChanged="FilterTypeChanged"/>
            <Button Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Padding="5" Click="Accept"
                    Background="LightGreen"
                    Foreground="Black"
                    >
                <SymbolIcon Symbol="Accept" />
            </Button>

            <Button Grid.Column="3" Click="ClearAll"
                    Padding="5"
                    Background="Salmon"
                    Foreground="Black">
                <SymbolIcon Symbol="ClearSelection"/>
            </Button>

        </Grid>

        <ScrollView Grid.Row="1">
            <ItemsRepeater x:Name="TagList">
                <ItemsRepeater.Layout>
                    <LinedFlowLayout/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:CheckTag">
                        <CheckBox Margin="5"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding IsChecked, Mode=TwoWay}">
                            <uc:TagCard DataContext="{Binding Tag}"
                                        Padding="15 2" CornerRadius="5"/>
                        </CheckBox>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollView>
    </Grid>
</Window>
