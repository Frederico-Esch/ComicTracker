<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ComicTracking.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComicTracking">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->
            <SolidColorBrush x:Key="Unread">Salmon</SolidColorBrush>
            <SolidColorBrush x:Key="Progress">Goldenrod</SolidColorBrush>
            <SolidColorBrush x:Key="Finished">LightGreen</SolidColorBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
