<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ComicTracking.UserControls.TagCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComicTracking.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:domain="using:Domain"
    mc:Ignorable="d"
    x:Name="UC"
    Loaded="UCLoaded">

    <UserControl.DataContext>
        <domain:Tag/>
    </UserControl.DataContext>

    <Border x:Name="BackgroundElement" BorderThickness="0"
            Margin="{Binding ElementName=UC, Path=Margin}"
            Padding="{Binding ElementName=UC, Path=Padding}"
            CornerRadius="{Binding ElementName=UC, Path=CornerRadius}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
    >
        <TextBlock x:Name="TagName" Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
</UserControl>
